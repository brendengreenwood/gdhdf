@use "../mixins.scss" as *;
@use "../variables.scss" as *;
@use "../base.scss" as *;
@use "../fonts.scss" as *;
@use "../reset.scss" as *;

:root {
  /** line height **/
  @include create-rem-vars($line-height-scale, "sprout-line-height");
  /** spacing in rem **/
  @include create-rem-vars($spacing-scale, "sprout-spacing");
  /** border radius **/
  @include create-rem-vars($border-radius-scale, "sprout-border-radius");
  /** padding **/
  @include create-rem-vars($padding-scale, "sprout-padding");
  /** font-size **/
  @include create-rem-vars($font-size-scale, "sprout-font-size");

  /** Motion **/
  --transition-interaction: 0.15s;
  --transition-standard: 0.35s;
  --transition-ripple: 0.75s;

  --sprout-spacing: 4px;
  --sprout-shape-borderRadius: 4px;
  --sprout-shadows-0: none;
  --sprout-shadows-1: 0px 4px 16px 0px rgba(0, 0, 0, 0.1);
  --sprout-shadows-2: 0px 12px 24px 0px rgba(0, 0, 0, 0.1);
  --sprout-shadows-3: 0px 12px 24px 0px rgba(0, 0, 0, 0.25);
  --sprout-shadows-4: 0px 16px 32px 0px rgba(0, 0, 0, 0.25);
  --sprout-shadows-5: 0 0 0 2px white;
  --sprout-shadows-6: 0 0 0 2px rgba(0, 132, 61, 0.7);
  --sprout-shadows-7: 0px 16px 32px 0px rgba(0, 0, 0, 0.45);
  --sprout-shadows-8: 0px 16px 32px 0px rgba(0, 0, 0, 0.65);
  --sprout-shadows-9: 0px 16px 32px 0px rgba(0, 0, 0, 0.85);
  --sprout-zIndex-mobileStepper: 1000;
  --sprout-zIndex-fab: 1050;
  --sprout-zIndex-speedDial: 1050;
  --sprout-zIndex-appBar: 1100;
  --sprout-zIndex-drawer: 1200;
  --sprout-zIndex-modal: 1300;
  --sprout-zIndex-snackbar: 1400;
  --sprout-zIndex-tooltip: 1500;
  --sprout-custom-CargillLogo: /src/assets/foundations/cargill-logo-light.svg;
  --sprout-custom-CargillLogoContrast: /src/assets/foundations/cargill-logo-dark.svg;

  --sprout-font-sans-serif: HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-serif: BigCaslonForCargill, serif;
  --sprout-font-micro: HelveticaNowMicroForCargill, serif;
  --sprout-font-weight-normal: 400;
  --sprout-font-weight-bold: 700;

  --sprout-font-h1: 400 3.5rem/4rem BigCaslonForCargill, serif;
  --sprout-font-h2: 700 2rem/2.625rem BigCaslonForCargill, serif;
  --sprout-font-h3: 700 1.75rem/2.25rem BigCaslonForCargill, serif;
  --sprout-font-h4: 700 1.5rem/2rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-h5: 700 1.25rem/1.625rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-h6: 700 1.125rem/1.5rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-subtitle1: 400 1.5rem/2rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-subtitle2: 400 1.25rem/1.625rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-body1: normal 400 1rem/1.5rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-body2: normal 400 0.75rem/1.125rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-button: normal 400 1rem/1.5rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-caption: normal 400 0.625rem/0.875rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-overline: normal 400 1.5rem/2rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-body_xs: normal 400 0.625rem/0.875rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-text_sm: normal 400 0.75rem/1.125rem HelveticaNowForCargill, Helvetica, sans-serif;
  --sprout-font-link: normal 400 1rem/1.5rem HelveticaNowForCargill, Helvetica, sans-serif;

  /* Primary Colors */
  --sprout-color-white: #ffffff;
  --sprout-color-brand-white: #ffffff;
  --sprout-color-green-100: #f5f9ed;
  --sprout-color-green-200: #bde588;
  --sprout-color-green-300: #81ab40;
  --sprout-color-green-400: #00843d;
  --sprout-color-green-700: #01632d;
  --sprout-color-green-800: #03441f;
  --sprout-color-green-900: #012912;
  --sprout-color-black: #000000;

  /* Named Colors */
  --sprout-color-soft-green: var(--sprout-color-green-200);
  --sprout-color-leaf-green: var(--sprout-color-green-400);
  --sprout-color-banner-green: var(--sprout-color-green-700);
  --sprout-color-deep-green: var(--sprout-color-green-800);
  --sprout-color-dark-green: var(--sprout-color-green-900);

  /* Greens */
  --sprout-palette-green-100: #f5f9ed;
  --sprout-palette-green-200: #bde588;
  --sprout-palette-green-300: #81ab40;
  --sprout-palette-green-400: #00843d;
  --sprout-palette-green-500: #00843d;
  --sprout-palette-green-700: #01632d;
  --sprout-palette-green-800: #03441f;
  --sprout-palette-green-900: #012912;

  /* Neutrals */
  --sprout-color-neutral-100: #f3f4f3;
  --sprout-color-neutral-200: #e7e8e8;
  --sprout-color-neutral-300: #dbdddc;
  --sprout-color-neutral-400: #9fa4a2;
  --sprout-color-neutral-500: #707773;
  --sprout-color-neutral-600: #58605c;
  --sprout-color-neutral-700: #404945;
  --sprout-color-neutral-800: #404945;
  --sprout-color-neutral-900: #1c2722;
  --sprout-color-neutral-1000: #101c16;

  /* Grays */
  --sprout-palette-gray-50: #fafafa;
  --sprout-palette-gray-100: #f5f5f5;
  --sprout-palette-gray-200: #eeeeee;
  --sprout-palette-gray-300: #e0e0e0;
  --sprout-palette-gray-400: #bdbdbd;
  --sprout-palette-gray-500: #9e9e9e;
  --sprout-palette-gray-600: #757575;
  --sprout-palette-gray-700: #616161;
  --sprout-palette-gray-800: #424242;
  --sprout-palette-gray-900: #212121;
  --sprout-palette-gray-A100: #f5f5f5;
  --sprout-palette-gray-A200: #eeeeee;
  --sprout-palette-gray-A400: #bdbdbd;
  --sprout-palette-gray-A700: #616161;

  /* Emphasis Colors */
  --sprout-color-ruby-red-100: #eb5655;
  --sprout-color-ruby-red-300: #c50f1f;
  --sprout-color-ruby-red-500: #c50f1f;
  --sprout-color-yolk-yellow-100: #fea800;
  --sprout-color-sapphire-blue-100: #55a5eb;
  --sprout-color-sapphire-blue-500: #0f49c5;

  /* Secondary Colors */
  --sprout-color-bright-yellow-100: #ffd77d;
  --sprout-color-bright-yellow-500: #ffbc27;
  --sprout-color-bright-yellow-700: #989a04;
  --sprout-color-bright-yellow-800: #ef8455;
  --sprout-color-bright-yellow-900: #ffd77d;
  --sprout-color-midnight-blue-100: #99adc2;
  --sprout-color-midnight-blue-400: #2d4e77;
  --sprout-color-midnight-blue-500: #003266;
  --sprout-color-midnight-blue-900: #001a33;
  --sprout-color-rich-green-700: #006630;
  --sprout-color-rich-red-100: #f7b9c0;
  --sprout-color-rich-red-500: #ea5062;
  --sprout-color-rich-red-600: #e01f1f;
  --sprout-color-rich-red-700: #b00715;
  --sprout-color-rich-red-800: #9e3a3c;
  --sprout-color-rich-red-900: #9e2a2f;
  --sprout-color-sky-blue-100: #bcedff;
  --sprout-color-sky-blue-500: #57d1ff;
  --sprout-color-sky-blue-700: #2666fd;
  --sprout-color-sky-blue-800: #3c8394;
  --sprout-color-sky-blue-900: #007681;
  --sprout-color-vibrabt-purple-100: #c6c2ff;
  --sprout-color-vibrant-purple-500: #7166ff;
  --sprout-color-vibrant-purple-700: #4b45a5;
  --sprout-color-vibrant-purple-900: #393380;

  /** border colors **/
  --border-interactive-error: var(--sprout-color-ruby-red-500);

/**********************************/
/*        design tokens dark      */
/**********************************/
:root {
  [data-theme="dark"] {
    -webkit-print-color-scheme: dark;
    color-scheme: dark;
    --sprout-palette-common-black: var(--sprout-color-black);
    --sprout-palette-common-white: var(--sprout-color-white);
    --sprout-palette-common-background: var(--sprout-color-black);
    --sprout-palette-common-onBackground: var(--sprout-color-white);
    --sprout-palette-common-backgroundChannel: 0 0 0;
    --sprout-palette-common-onBackgroundChannel: 255 255 255;

    --sprout-palette-primary-main: var(--sprout-color-green-200);
