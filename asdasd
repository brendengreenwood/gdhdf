    --sprout-palette-border-disabled: var(--sprout-color-neutral-800);
    --sprout-palette-border-alert: var(--sprout-color-ruby-red-100);
    --sprout-palette-border-input: var(--sprout-color-neutral-500);
    --sprout-palette-border-inverse: var(--sprout-color-neutral-1000);
    --sprout-palette-border-light: var(--sprout-color-white);
    --sprout-palette-border-dark: var(--sprout-color-neutral-1000);
    --sprout-palette-border-lightChannel: 255 255 255;
    --sprout-palette-border-darkChannel: 16 28 22; /* approx text dark channel */

    --sprout-palette-icon-main: var(--sprout-color-neutral-300);
    --sprout-palette-icon-inverse: var(--sprout-color-green-900);
    --sprout-palette-icon-brand: var(--sprout-color-green-200);
