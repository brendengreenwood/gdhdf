    --sprout-palette-error-lightChannel: 229 115 115;
    --sprout-palette-error-darkChannel: 211 47 47;
    --sprout-palette-error-contrastTextChannel: 255 255 255;

    --sprout-palette-warning-main: var(--sprout-color-ruby-red-500);
