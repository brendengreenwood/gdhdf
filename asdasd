    --sprout-palette-success-lightChannel: 129 199 132;
    --sprout-palette-success-darkChannel: 56 142 60;
    --sprout-palette-success-contrastTextChannel: 0 0 0;

    --sprout-palette-text-primary: var(--sprout-color-white);
    --sprout-palette-text-secondary: var(--sprout-color-neutral-400);
    --sprout-palette-text-disabled: var(--sprout-color-neutral-500);
    --sprout-palette-text-primaryHover: var(--sprout-color-neutral-300);
