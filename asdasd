    --sprout-palette-text-selected: var(--sprout-color-green-100);
    --sprout-palette-text-interactive: var(--sprout-color-green-200);
    --sprout-palette-text-interactiveHover: var(--sprout-color-green-300);
    --sprout-palette-text-visited: var(--sprout-color-green-300);
    --sprout-palette-text-header: var(--sprout-color-green-200);
