    --sprout-palette-emphasis-surface: var(--sprout-color-neutral-800);
    --sprout-palette-emphasis-positive: var(--sprout-color-leaf-green);
    --sprout-palette-emphasis-negative: var(--sprout-color-ruby-red-100);
    --sprout-palette-emphasis-info: var(--sprout-color-sapphire-blue-500);
    --sprout-palette-emphasis-warning: var(--sprout-color-yolk-yellow-100);
    --sprout-palette-emphasis-announcement: var(--sprout-color-neutral-300);
    --sprout-palette-emphasis-skeleton: var(--sprout-color-neutral-200);

